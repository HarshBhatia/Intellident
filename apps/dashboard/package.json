{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "rm -rf .next && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:e2e": "E2E_TEST_SECRET=e2e-secret-key playwright test",
    "test:e2e:ui": "E2E_TEST_SECRET=e2e-secret-key playwright test --ui",
    "test:e2e:headed": "E2E_TEST_SECRET=e2e-secret-key playwright test --headed",
    "test:e2e:debug": "E2E_TEST_SECRET=e2e-secret-key playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:run": "./run-e2e-tests.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.1",
    "@clerk/themes": "^2.4.57",
    "@google/generative-ai": "^0.24.1",
    "@intellident/api": "*",
    "@netlify/neon": "^0.1.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.0.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "jest": "^30.2.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^30.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "@playwright/test": "^1.49.1"
  }
}
