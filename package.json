{
  "name": "intellident-monorepo",
  "private": true,
  "packageManager": "npm@10.2.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test:unit": "npm test --workspace=dashboard",
    "test:e2e": "npm run test:e2e --workspace=dashboard",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "lightningcss-linux-x64-gnu": "1.31.1"
  }
}
