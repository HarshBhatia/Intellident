#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-push checks..."

# Run build to ensure code compiles
echo "📦 Building project..."
DATABASE_URL=postgres://dummy:dummy@localhost:5432/dummy npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build failed. Push aborted."
  exit 1
fi

echo "✅ Build passed. Proceeding with push..."
echo "   (E2E tests skipped - run manually with: npm run test:e2e -w dashboard)"
exit 0
